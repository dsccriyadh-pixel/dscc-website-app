# DSCC Hostinger config — compression + cache + SPA routing

# ---------- Gzip / Brotli compression ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml text/xml image/svg+xml application/manifest+json font/ttf font/otf application/font-woff application/font-woff2
</IfModule>
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript application/javascript application/json image/svg+xml application/manifest+json
</IfModule>

# ---------- Cache headers ----------
<IfModule mod_expires.c>
  ExpiresActive On
  # Hashed assets — cache forever
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Images — long cache
  <FilesMatch "\.(webp|avif|jpg|jpeg|png|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # PDFs — medium cache
  <FilesMatch "\.pdf$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
  # HTML — must revalidate
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------- MIME for modern formats ----------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
  AddType application/manifest+json .webmanifest
  AddType font/woff2 .woff2
</IfModule>

# ---------- Security headers ----------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ---------- SPA fallback (React Router) ----------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # NEVER rewrite static file extensions — let Apache return real 404 if missing
  RewriteCond %{REQUEST_URI} \.(pdf|png|jpe?g|webp|avif|gif|svg|ico|css|js|mjs|map|json|xml|txt|woff2?|ttf|otf|eot|mp4|webm|mp3|wav|zip)$ [NC]
  RewriteRule ^ - [L]

  # Map clean /api/chat to /api/chat.php (Sara chatbot — OpenAI proxy)
  RewriteRule ^api/chat/?$ /api/chat.php [L]
  RewriteRule ^api/leads/?$ /api/leads.php [L]

  # Skip API and static asset directories
  RewriteRule ^(api|assets|img|downloads|fonts)/ - [L]

  # Skip existing files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA: everything else → index.html
  RewriteRule . /index.html [L]
</IfModule>

# ---------- Disable directory listing ----------
Options -Indexes
